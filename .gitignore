# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Dependencies ───────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Testing ────────────────────────────────────────────────
/coverage

# ── Next.js ────────────────────────────────────────────────
/.next/
/out/

# ── Production ─────────────────────────────────────────────
/build

# ── OS / Editor ────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
*.swp
*.swo
*~

# ── Debug ──────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.html.bak
sed.out

# ── Env files ──────────────────────────────────────────────
.env*
!.env.example

# ── Vercel ─────────────────────────────────────────────────
.vercel

# ── TypeScript ─────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Prisma ─────────────────────────────────────────────────
/lib/generated/prisma

# ── Python / Django ────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.pytest_cache/
backend/hiringnow/db.sqlite3
backend/hiringnow/.coverage

# ── Temp / generated ──────────────────────────────────────
/tmp/
cookies.txt
