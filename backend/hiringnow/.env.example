# The SECRET_KEY is the secret key for the project.
# The secret key is used to sign the session cookies and the CSRF tokens.
# It is also used to sign the JWT tokens.
# It is important to keep this secret and not to share it with anyone.
SECRET_KEY=your-secret-key-here

# The database settings for the project.
DB_NAME=your-database-name-here
DB_USER=your-database-user-here
DB_PASSWORD=your-database-password-here
DB_HOST=your-database-host-here
DB_PORT=your-database-port-here

# The Redis settings for the project.
REDIS_URL=your-redis-url-here

# The DJANGO_ENV setting is the environment for the project.
DJANGO_ENV=your-environment-here

# This is a list of all the hosts that are allowed to access the project.
ALLOWED_HOSTS=your-host-here