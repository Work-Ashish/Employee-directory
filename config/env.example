# =============================================================================
# HRMS Microservice — Environment Variables
# =============================================================================
# Copy to .env and fill in values. Variables marked [EMBEDDED] are only needed
# when running as part of the HiringNow Platform.

# --- Django Backend ---
SECRET_KEY=your-secret-key-here
DB_NAME=recruitment_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432
TENANT_DB_NAME_PREFIX=recruitment_db_
TENANT_DB_SLUGS=acme,demo
REDIS_URL=redis://localhost:6379/0

# --- Next.js Frontend ---
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=your-nextauth-secret
GEMINI_API_KEY=your-gemini-key

# --- [EMBEDDED] Multi-Zone / Microservice ---
# Set when running as HRMS module inside HiringNow Platform
NEXT_PUBLIC_BASE_PATH=           # "/hrms" when embedded, empty when standalone
NEXT_PUBLIC_EMBEDDED=false       # "true" to hide local sidebar/topbar
NEXT_PUBLIC_PLATFORM_LOGIN_URL=  # e.g. "http://localhost:3000/login" (parent platform login)

# --- [EMBEDDED] API Gateway ---
DJANGO_GATEWAY_URL=              # e.g. "http://gateway/api/v1/hrms" (Nginx gateway URL)
DJANGO_INTERNAL_URL=             # e.g. "http://hrms-django:8001" (direct container URL)

# --- CORS (Django) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost
CORS_ALLOWED_ORIGIN_REGEXES=
CSRF_TRUSTED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:3001
