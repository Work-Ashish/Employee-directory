generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Organization {
  id                 String               @id @default(cuid())
  name               String
  domain             String?              @unique
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  users              User[]
  employees          Employee[]
  departments        Department[]
  announcements      Announcement[]
  candidates         Candidate[]
  leaves             Leave[]
  attendances        Attendance[]
  tickets            Ticket[]
  performanceMetrics PerformanceMetrics[]
  weeklyScores       WeeklyScores[]
  notifications      Notifications[]
  adminAlerts        AdminAlerts[]
  assets             Asset[]
  documents          Document[]
  payroll            Payroll[]
  providentFunds     ProvidentFund[]
  performanceReviews PerformanceReview[]
  resignations       Resignation[]
  trainings          Training[]
  events             CalendarEvent[]
  trainingEnrollments TrainingEnrollment[]
  documentEmbeddings DocumentEmbedding[]

  // Workflows
  workflowTemplates  WorkflowTemplate[]
  workflowInstances  WorkflowInstance[]

  // Payroll Configs
  payrollConfigs     PayrollComplianceConfig[]
  payrollAudits      PayrollAudit[]
}

model User {
  id                 String        @id @default(cuid())
  name               String
  email              String        @unique
  hashedPassword     String
  role               Role          @default(EMPLOYEE)
  organizationId     String
  organization       Organization  @relation(fields: [organizationId], references: [id])
  avatar             String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  accentColor        String?       @default("blue")
  bio                String?
  lastLoginAt        DateTime?
  mustChangePassword Boolean       @default(false)
  employee           Employee?
}

model Department {
  id             String        @id @default(cuid())
  name           String
  color          String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  candidates     Candidate[]
  employees      Employee[]

  @@index([organizationId])
  @@unique([name, organizationId])
}

model Employee {
  id             String         @id @default(cuid())
  employeeCode   String         @unique
  firstName      String
  lastName       String
  email          String         @unique
  phone          String?
  designation    String
  departmentId   String
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  dateOfJoining  DateTime
  salary         Float
  status         EmployeeStatus @default(ACTIVE)
  avatarUrl      String?
  address        String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  userId         String?        @unique
  managerId      String?

  // Sub-profiles
  profile     EmployeeProfile?
  addressInfo EmployeeAddress?
  banking     EmployeeBanking?

  // Relations
  assets             Asset[]
  attendanceRecords  Attendance[]
  documents          Document[]
  educations         Education[]
  department         Department           @relation(fields: [departmentId], references: [id])
  manager            Employee?            @relation("EmployeeToManager", fields: [managerId], references: [id])
  reports            Employee[]           @relation("EmployeeToManager")
  user               User?                @relation(fields: [userId], references: [id])
  leaves             Leave[]
  payrollRecords     Payroll[]
  performanceReviews PerformanceReview[]
  pfRecords          ProvidentFund[]
  resignations       Resignation[]
  tickets            Ticket[]
  trainings          TrainingEnrollment[]
  timeSessions       TimeSession[]
  performanceMetrics PerformanceMetrics[]
  weeklyScores       WeeklyScores[]
  notifications      Notifications[]
  adminAlerts        AdminAlerts[]

  // Workflows
  requestedWorkflows WorkflowInstance[] @relation("WorkflowRequester")
  workflowActions    WorkflowAction[]   @relation("WorkflowActor")

  @@index([departmentId])
  @@index([userId])
  @@index([managerId])
  @@index([email])
  @@index([status])
  @@index([organizationId])
}

model EmployeeProfile {
  id         String   @id @default(cuid())
  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // Personal
  dateOfBirth           DateTime?
  gender                String?
  bloodGroup            String?
  nationality           String?
  maritalStatus         String?
  marriageDate          DateTime?
  spouse                String?
  placeOfBirth          String?
  residentialStatus     String?
  fatherName            String?
  religion              String?
  physicallyChallenged  Boolean?  @default(false)
  internationalEmployee Boolean?  @default(false)
  hobby                 String?
  caste                 String?
  height                String?
  weight                String?
  identificationMark    String?

  // Family – Father
  fatherDob         DateTime?
  fatherBloodGroup  String?
  fatherGender      String?
  fatherNationality String?

  // Emergency Contact
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?

  // Employment extras
  category           String?
  costCenter         String?
  division           String?
  grade              String?
  location           String?
  previousEmployment String?

  // Passport & Visa
  passportNumber String?
  passportExpiry DateTime?
  visaNumber     String?
  visaExpiry     DateTime?
}

model EmployeeAddress {
  id         String   @id @default(cuid())
  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // Current/Contact Address
  contactAddress String?
  contactCity    String?
  contactState   String?
  contactPincode String?

  // Permanent Address
  permanentAddress String?
  permanentCity    String?
  permanentState   String?
  permanentPincode String?
}

model EmployeeBanking {
  id         String   @id @default(cuid())
  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // Bank & Statutory
  bankName          String?
  bankAccountNumber String?
  bankBranch        String?
  ifscCode          String?
  pfAccountNumber   String?
  aadhaarNumber     String?
  panNumber         String?
}

model Education {
  id         String   @id @default(cuid())
  degree     String
  institute  String
  duration   String?
  grade      String?
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

model Asset {
  id             String       @id @default(cuid())
  name           String
  type           AssetType
  serialNumber   String       @unique
  status         AssetStatus  @default(AVAILABLE)
  purchaseDate   DateTime
  value          Float
  image          String?
  assignedToId   String?
  assignedDate   DateTime?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  assignedTo     Employee?    @relation(fields: [assignedToId], references: [id])

  @@index([assignedToId])
  @@index([status])
  @@index([organizationId])
}

model Document {
  id             String       @id @default(cuid())
  title          String
  category       DocCategory
  url            String
  size           String?
  isPublic       Boolean      @default(false)
  employeeId     String?
  organizationId String
  uploadDate     DateTime     @default(now())
  employee       Employee?    @relation(fields: [employeeId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([employeeId])
  @@index([organizationId])
}

model Leave {
  id             String        @id @default(cuid())
  type           LeaveType
  startDate      DateTime
  endDate        DateTime
  reason         String?
  status         LeaveStatus   @default(PENDING)
  employeeId     String
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  employee       Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization   Organization  @relation(fields: [organizationId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([employeeId, startDate, endDate])
  @@index([organizationId])
}

model Resignation {
  id             String            @id @default(cuid())
  reason         String
  lastDay        DateTime
  status         ResignationStatus @default(UNDER_REVIEW)
  employeeId     String
  organizationId String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  employee       Employee          @relation(fields: [employeeId], references: [id])
  organization   Organization      @relation(fields: [organizationId], references: [id])

  @@index([employeeId])
  @@index([organizationId])
}

model Attendance {
  id             String           @id @default(cuid())
  date           DateTime
  checkIn        DateTime?
  checkOut       DateTime?
  workHours      Float?
  status         AttendanceStatus @default(PRESENT)
  employeeId     String
  organizationId String
  createdAt      DateTime         @default(now())
  employee       Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id])

  @@index([employeeId])
  @@index([date])
  @@index([employeeId, date])
  @@index([organizationId])
}

model Payroll {
  id             String       @id @default(cuid())
  month          String
  basicSalary    Float
  allowances     Float        @default(0)
  pfDeduction    Float        @default(0)
  tax            Float        @default(0)
  otherDed       Float        @default(0)

  // Advanced Components (New)
  arrears        Float        @default(0)
  reimbursements Float        @default(0)
  loansAdvances  Float        @default(0)

  netSalary      Float
  status         PayrollStatus @default(PENDING)
  isFinalized    Boolean      @default(false)
  pdfUrl         String?
  
  employeeId     String
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  
  employee       Employee      @relation(fields: [employeeId], references: [id])
  organization   Organization  @relation(fields: [organizationId], references: [id])
  audits         PayrollAudit[]

  @@index([employeeId])
  @@index([organizationId])
}

model ProvidentFund {
  id                   String       @id @default(cuid())
  month                String
  accountNumber        String
  basicSalary          Float
  employeeContribution Float
  employerContribution Float
  totalContribution    Float
  status               String       @default("Credited")
  employeeId           String
  organizationId       String
  createdAt            DateTime     @default(now())
  employee             Employee     @relation(fields: [employeeId], references: [id])
  organization         Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model PerformanceReview {
  id             String            @id @default(cuid())
  rating         Float
  progress       Int               @default(0)
  comments       String?
  reviewDate     DateTime          @default(now())
  status         PerformanceStatus @default(PENDING)
  employeeId     String
  organizationId String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  employee       Employee          @relation(fields: [employeeId], references: [id])
  organization   Organization      @relation(fields: [organizationId], references: [id])

  @@index([employeeId])
  @@index([organizationId])
}

model Training {
  id             String               @id @default(cuid())
  name           String
  type           TrainingType
  description    String?
  status         TrainingStatus       @default(UPCOMING)
  progress     Int                  @default(0)
  dueDate      DateTime?
  participants Int                  @default(0)
  videoUrl     String?
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id])
  createdAt    DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  enrollments  TrainingEnrollment[]

  @@index([organizationId])
}

model TrainingEnrollment {
  id             String       @id @default(cuid())
  score          Int?
  completed      Boolean      @default(false)
  trainingId     String
  employeeId     String
  organizationId String
  enrolledAt     DateTime     @default(now())
  employee       Employee     @relation(fields: [employeeId], references: [id])
  training       Training     @relation(fields: [trainingId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([trainingId, employeeId])
  @@index([organizationId])
}

model Announcement {
  id             String               @id @default(cuid())
  title          String
  content        String
  author         String
  category       AnnouncementCategory
  priority       AnnouncementPriority @default(MEDIUM)
  isPinned       Boolean              @default(false)
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id])
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([organizationId])
}

model Ticket {
  id             String         @id @default(cuid())
  ticketCode     String         @unique
  subject        String
  description    String?
  category       TicketCategory
  priority       TicketPriority @default(MEDIUM)
  status         TicketStatus   @default(OPEN)
  employeeId     String
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  employee       Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization   Organization   @relation(fields: [organizationId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([organizationId])
}

model CalendarEvent {
  id             String       @id @default(cuid())
  title          String
  start          DateTime
  end            DateTime
  allDay         Boolean      @default(false)
  type           EventType    @default(EVENT)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([organizationId])
}

model Candidate {
  id             String          @id @default(cuid())
  name           String
  email          String
  phone          String?
  role           String
  stage          CandidateStage  @default(APPLICATION)
  status         CandidateStatus @default(NEW)
  interviewDate  DateTime?
  notes          String?
  departmentId   String?
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  department     Department?     @relation(fields: [departmentId], references: [id])

  @@index([organizationId])
}

model DocumentEmbedding {
  id             String                          @id @default(cuid())
  content        String
  embedding      Unsupported("vector(1536)")
  metadata       Json?
  organizationId String
  organization   Organization                    @relation(fields: [organizationId], references: [id])
  createdAt      DateTime                        @default(now())

  @@index([organizationId])
}

// ─── Time Tracking ───

model TimeSession {
  id         String             @id @default(cuid())
  employeeId String
  checkIn    DateTime           @default(now())
  checkOut   DateTime?
  totalWork  Int                @default(0)
  totalBreak Int                @default(0)
  totalIdle  Int                @default(0)
  status     SessionStatus      @default(ACTIVE)
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime           @default(now())
  employee   Employee           @relation(fields: [employeeId], references: [id])
  breaks     BreakEntry[]
  activities ActivityLog[]
  snapshots  ActivitySnapshot[]

  @@index([employeeId])
  @@index([createdAt])
  @@index([employeeId, createdAt])
}

model BreakEntry {
  id        String      @id @default(cuid())
  sessionId String
  startedAt DateTime    @default(now())
  endedAt   DateTime?
  reason    String?
  session   TimeSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
}

model ActivityLog {
  id          String           @id @default(cuid())
  sessionId   String
  appName     String
  windowTitle String?
  url         String?
  domain      String?
  category    ActivityCategory @default(OTHER)
  startedAt   DateTime         @default(now())
  endedAt     DateTime?
  durationSec Int              @default(0)
  session     TimeSession      @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
}

model ActivitySnapshot {
  id          String         @id @default(cuid())
  sessionId   String
  status      ActivityStatus @default(ACTIVE)
  timestamp   DateTime       @default(now())
  mouseClicks Int            @default(0)
  keystrokes  Int            @default(0)
  session     TimeSession    @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
}

// --- PHASE 6: AUTONOMOUS PERFORMANCE MONITORING AGENT ---

model PerformanceMetrics {
  id             String    @id @default(cuid())
  employeeId     String
  date           DateTime
  activeSeconds  Int       @default(0)
  idleSeconds    Int       @default(0)
  tasksCompleted Int       @default(0)
  qualityScore   Decimal?  @db.Decimal(5, 2)
  organizationId String
  
  employee     Employee      @relation(fields: [employeeId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([employeeId, date])
  @@index([organizationId])
}

model WeeklyScores {
  id               String    @id @default(cuid())
  evaluationHash   String    @unique // Format: emp123_2026_w42
  employeeId       String
  weekStartDate    DateTime
  baseScore        Decimal   @db.Decimal(5, 2)
  aiAdjustment     Decimal   @db.Decimal(5, 2)
  finalScore       Decimal   @db.Decimal(5, 2)
  confidenceScore  Decimal   @db.Decimal(5, 2) 
  burnoutRisk      Boolean   @default(false)
  behavioralAnomaly Boolean  @default(false)
  aiFeedback       String?   @db.Text
  organizationId   String

  employee      Employee      @relation(fields: [employeeId], references: [id])
  organization  Organization  @relation(fields: [organizationId], references: [id])
  notifications Notifications[]

  @@index([employeeId])
  @@index([organizationId])
}

model AgentExecutionLogs {
  id                 String    @id @default(cuid())
  batchId            String
  weekNumber         Int
  employeesProcessed Int       @default(0)
  errors             Int       @default(0)
  status             AgentRunStatus @default(RUNNING)
  durationMs         Int       @default(0)
  createdAt          DateTime  @default(now())
}

model Notifications {
  id             String    @id @default(cuid())
  employeeId     String
  type           NotificationType
  evaluationHash String    @unique
  status         NotificationStatus @default(PENDING)
  sentAt         DateTime?
  organizationId String

  employee     Employee      @relation(fields: [employeeId], references: [id])
  weeklyScore  WeeklyScores  @relation(fields: [evaluationHash], references: [evaluationHash])
  organization Organization  @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model AdminAlerts {
  id             String    @id @default(cuid())
  employeeId     String
  severity       AdminAlertSeverity
  reason         String    @db.Text
  resolved       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  organizationId String
  
  employee     Employee      @relation(fields: [employeeId], references: [id])
  organization Organization  @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

// ─── Enums ───

enum Role {
  ADMIN
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  RESIGNED
  TERMINATED
}

enum AssetType {
  HARDWARE
  SOFTWARE
  ACCESSORY
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
}

enum DocCategory {
  POLICY
  CONTRACT
  PAYSLIP
  TAX
  IDENTIFICATION
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  MATERNITY
  PATERNITY
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ResignationStatus {
  UNDER_REVIEW
  NOTICE_PERIOD
  PROCESSED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  ON_LEAVE
  WEEKEND
}

enum PayrollStatus {
  PENDING
  PROCESSED
  PAID
}

enum PerformanceStatus {
  PENDING
  COMPLETED
  EXCELLENT
  GOOD
  NEEDS_IMPROVEMENT
}

enum TrainingType {
  TECHNICAL
  COMPLIANCE
  SECURITY
  SOFT_SKILLS
  LEADERSHIP
  ONBOARDING
  OTHER
}

enum TrainingStatus {
  UPCOMING
  IN_PROGRESS
  COMPLETED
}

enum AnnouncementCategory {
  EVENT
  POLICY
  MEETING
  SYSTEM
  GENERAL
}

enum AnnouncementPriority {
  LOW
  MEDIUM
  HIGH
}

enum TicketCategory {
  IT
  HR
  FINANCE
  FACILITIES
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum EventType {
  HOLIDAY
  LEAVE
  BIRTHDAY
  EVENT
  MEETING
}

enum CandidateStage {
  APPLICATION
  SCREENING
  INTERVIEW
  TECHNICAL_ROUND
  OFFER
  HIRED
  REJECTED
}

enum CandidateStatus {
  NEW
  SCHEDULED
  EVALUATED
  PENDING
  ACCEPTED
  REJECTED
}

enum SessionStatus {
  ACTIVE
  BREAK
  COMPLETED
}

enum ActivityCategory {
  PRODUCTIVITY
  COMMUNICATION
  DESIGN
  RESEARCH
  ENTERTAINMENT
  SOCIAL_MEDIA
  OTHER
}

enum ActivityStatus {
  ACTIVE
  IDLE
  BREAK
}

enum AgentRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum NotificationType {
  APPRECIATION
  IMPROVEMENT
  ESCALATION
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum AdminAlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ─── Phase 2: Workflow Engine ───

model WorkflowTemplate {
  id             String         @id @default(cuid())
  name           String
  description    String?
  entityType     String         // e.g., "LEAVE", "ASSET", "EXPENSE"
  status         WorkflowStatus @default(DRAFT)
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  organization   Organization   @relation(fields: [organizationId], references: [id])
  steps          WorkflowStep[]
  instances      WorkflowInstance[]

  @@index([organizationId])
  @@index([entityType])
}

model WorkflowStep {
  id             String       @id @default(cuid())
  templateId     String
  stepOrder      Int          // 1, 2, 3...
  approverType   ApproverType
  role           String?      // If approverType is ROLE
  userId         String?      // If approverType is SPECIFIC_USER
  slaHours       Int?         // SLA in hours
  autoAction     String?      // e.g. "APPROVE", "ESCALATE" on SLA breach
  
  template       WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  actions        WorkflowAction[]

  @@index([templateId])
}

model WorkflowInstance {
  id             String         @id @default(cuid())
  templateId     String
  entityId       String         // ID of Leave, Asset Request, etc.
  status         InstanceStatus @default(PENDING)
  currentStep    Int            @default(1)
  organizationId String
  requesterId    String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  template       WorkflowTemplate @relation(fields: [templateId], references: [id])
  organization   Organization     @relation(fields: [organizationId], references: [id])
  requester      Employee         @relation("WorkflowRequester", fields: [requesterId], references: [id])
  actions        WorkflowAction[]

  @@index([templateId])
  @@index([entityId])
  @@index([organizationId])
}

model WorkflowAction {
  id             String         @id @default(cuid())
  instanceId     String
  stepId         String
  actorId        String
  action         ApprovalAction
  comments       String?
  createdAt      DateTime       @default(now())

  instance       WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  step           WorkflowStep     @relation(fields: [stepId], references: [id])
  actor          Employee         @relation("WorkflowActor", fields: [actorId], references: [id])

  @@index([instanceId])
  @@index([stepId])
}

enum WorkflowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum InstanceStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalAction {
  APPROVE
  REJECT
  REQUEST_INFO
}

enum ApproverType {
  MANAGER
  ROLE
  SPECIFIC_USER
}

// ─── Phase 2: Core HRMS Phase 2 - Payroll Compliance ───

model PayrollComplianceConfig {
  id                  String       @id @default(cuid())
  regimeName          String       @default("DEFAULT")
  pfPercentage        Float        @default(12.0)
  standardDeduction   Float        @default(50000.0)
  healthCess          Float        @default(4.0)
  isActive            Boolean      @default(true)
  organizationId      String
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  
  organization        Organization @relation(fields: [organizationId], references: [id])
  taxSlabs            TaxSlab[]

  @@index([organizationId])
}

model TaxSlab {
  id          String   @id @default(cuid())
  configId    String
  minIncome   Float
  maxIncome   Float?
  taxRate     Float    // e.g. 0.05 for 5%
  baseTax     Float    @default(0) // Precomputed tax for previous slabs
  
  config      PayrollComplianceConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
}

model PayrollAudit {
  id             String             @id @default(cuid())
  payrollId      String
  action         PayrollAuditAction
  actorId        String             // ID of user who performed the action
  details        String?            // JSON string of changes
  organizationId String
  createdAt      DateTime           @default(now())
  
  payroll        Payroll            @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  organization   Organization       @relation(fields: [organizationId], references: [id])

  @@index([payrollId])
  @@index([organizationId])
  @@index([actorId])
}

enum PayrollAuditAction {
  RUN_CALCULATION
  MANUAL_OVERRIDE
  FINALIZED
  LOCKED
}
