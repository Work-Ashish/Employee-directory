// ─── Phase 2: Workflow Engine ───

model WorkflowTemplate {
  id             String         @id @default(cuid())
  name           String
  description    String?
  entityType     String         // e.g., "LEAVE", "ASSET", "EXPENSE"
  status         WorkflowStatus @default(DRAFT)
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  organization   Organization   @relation(fields: [organizationId], references: [id])
  steps          WorkflowStep[]
  instances      WorkflowInstance[]

  @@index([organizationId])
  @@index([entityType])
}

model WorkflowStep {
  id             String       @id @default(cuid())
  templateId     String
  stepOrder      Int          // 1, 2, 3...
  approverType   ApproverType
  role           String?      // If approverType is ROLE
  userId         String?      // If approverType is SPECIFIC_USER
  slaHours       Int?         // SLA in hours
  autoAction     String?      // e.g. "APPROVE", "ESCALATE" on SLA breach
  
  template       WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  actions        WorkflowAction[]

  @@index([templateId])
}

model WorkflowInstance {
  id             String         @id @default(cuid())
  templateId     String
  entityId       String         // ID of Leave, Asset Request, etc.
  status         InstanceStatus @default(PENDING)
  currentStep    Int            @default(1)
  organizationId String
  requesterId    String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  template       WorkflowTemplate @relation(fields: [templateId], references: [id])
  organization   Organization     @relation(fields: [organizationId], references: [id])
  requester      Employee         @relation("WorkflowRequester", fields: [requesterId], references: [id])
  actions        WorkflowAction[]

  @@index([templateId])
  @@index([entityId])
  @@index([organizationId])
}

model WorkflowAction {
  id             String         @id @default(cuid())
  instanceId     String
  stepId         String
  actorId        String
  action         ApprovalAction
  comments       String?
  createdAt      DateTime       @default(now())

  instance       WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  step           WorkflowStep     @relation(fields: [stepId], references: [id])
  actor          Employee         @relation("WorkflowActor", fields: [actorId], references: [id])

  @@index([instanceId])
  @@index([stepId])
}

enum WorkflowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum InstanceStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalAction {
  APPROVE
  REJECT
  REQUEST_INFO
}

enum ApproverType {
  MANAGER
  ROLE
  SPECIFIC_USER
}

// ─── Phase 2: Core HRMS Phase 2 - Payroll Compliance ───

model PayrollComplianceConfig {
  id                  String       @id @default(cuid())
  regimeName          String       @default("DEFAULT")
  pfPercentage        Float        @default(12.0)
  standardDeduction   Float        @default(50000.0)
  healthCess          Float        @default(4.0)
  isActive            Boolean      @default(true)
  organizationId      String
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  
  organization        Organization @relation(fields: [organizationId], references: [id])
  taxSlabs            TaxSlab[]

  @@index([organizationId])
}

model TaxSlab {
  id          String   @id @default(cuid())
  configId    String
  minIncome   Float
  maxIncome   Float?
  taxRate     Float    // e.g. 0.05 for 5%
  baseTax     Float    @default(0) // Precomputed tax for previous slabs
  
  config      PayrollComplianceConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
}

model PayrollAudit {
  id             String             @id @default(cuid())
  payrollId      String
  action         PayrollAuditAction
  actorId        String             // ID of user who performed the action
  details        String?            // JSON string of changes
  organizationId String
  createdAt      DateTime           @default(now())
  
  payroll        Payroll            @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  organization   Organization       @relation(fields: [organizationId], references: [id])

  @@index([payrollId])
  @@index([organizationId])
  @@index([actorId])
}

enum PayrollAuditAction {
  RUN_CALCULATION
  MANUAL_OVERRIDE
  FINALIZED
  LOCKED
}

// ─── Phase 2: Core HRMS Phase 2 - Integrations & Webhooks (Week 8) ───

model Webhook {
  id             String            @id @default(cuid())
  url            String
  secret         String?           // For HMAC signing
  events         String[]          // Array of event types (e.g., ["PAYROLL.FINALIZED", "EMPLOYEE.CREATED"])
  isActive       Boolean           @default(true)
  organizationId String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization   Organization      @relation(fields: [organizationId], references: [id])
  deliveries     WebhookDelivery[]

  @@index([organizationId])
}

model WebhookDelivery {
  id             String                @id @default(cuid())
  webhookId      String
  event          String
  payload        Json
  responseCode   Int?
  responseBody   String?
  status         WebhookDeliveryStatus @default(PENDING)
  retryCount     Int                   @default(0)
  nextRetryAt    DateTime?
  createdAt      DateTime              @default(now())

  webhook        Webhook               @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([status])
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

// ─── Phase 3: Reporting & Analytics (Week 10) ───

model SavedReport {
  id             String           @id @default(cuid())
  name           String
  description    String?
  config         Json             // Stores columns, filters, sorting, grouping
  entityType     ReportEntityType
  organizationId String
  creatorId      String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  schedules      ReportSchedule[]

  @@index([organizationId])
}

model ReportSchedule {
  id             String           @id @default(cuid())
  reportId       String
  frequency      ReportFrequency
  format         ReportFormat     @default(CSV)
  recipients     String[]         // Email addresses
  lastRunAt      DateTime?
  nextRunAt      DateTime
  isActive       Boolean          @default(true)
  organizationId String
  createdAt      DateTime         @default(now())

  report         SavedReport      @relation(fields: [reportId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([reportId])
}

enum ReportEntityType {
  EMPLOYEE
  PAYROLL
  ATTENDANCE
  PERFORMANCE
  LEAVE
}

enum ReportFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum ReportFormat {
  CSV
  PDF
}

model InAppNotification {
  id             String       @id @default(cuid())
  userId         String
  title          String
  description    String
  type           String       @default("INFO") // INFO, SUCCESS, WARNING, ERROR
  isRead         Boolean      @default(false)
  organizationId String
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@index([createdAt])
}

// ─── Agent Tracking System ───

enum AgentDeviceStatus {
  PENDING
  ACTIVE
  SUSPENDED
  UNINSTALLED
}

enum AgentCommandType {
  UNINSTALL
  WIPE_DATA
  SUSPEND
  RESUME
  UPDATE_CONFIG
  FORCE_UPDATE
  FORCE_SYNC
  KILL_SWITCH
}

enum CommandStatus {
  PENDING_CMD
  DELIVERED
  EXECUTED
  FAILED_CMD
  EXPIRED
}

enum IdleResponse {
  YES
  NO
  TIMEOUT
}

model AgentDevice {
  id             String            @id @default(cuid())
  employeeId     String
  organizationId String
  deviceName     String
  platform       String            // "windows" | "macos" | "linux"
  fingerprint    String            @unique
  apiKey         String            @unique
  agentVersion   String
  status         AgentDeviceStatus @default(PENDING)
  lastHeartbeat  DateTime?
  lastSyncAt     DateTime?
  configJson     Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  employee     Employee                  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization Organization              @relation(fields: [organizationId], references: [id])
  commands     AgentCommand[]
  snapshots    AgentActivitySnapshot[]

  @@index([employeeId])
  @@index([organizationId])
  @@index([status])
}

model AgentCommand {
  id          String           @id @default(cuid())
  deviceId    String
  type        AgentCommandType
  status      CommandStatus    @default(PENDING_CMD)
  payload     Json?
  issuedBy    String
  issuedAt    DateTime         @default(now())
  deliveredAt DateTime?
  executedAt  DateTime?
  expiresAt   DateTime?
  result      String?

  device AgentDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([status])
}

model AgentActivitySnapshot {
  id                String           @id @default(cuid())
  sessionId         String
  deviceId          String
  timestamp         DateTime         @default(now())
  keystrokeCount    Int              @default(0)
  mouseClickCount   Int              @default(0)
  mouseDistance      Float            @default(0)
  scrollCount       Int              @default(0)
  activeSeconds     Int              @default(0)
  idleSeconds       Int              @default(0)
  productivityScore Float?
  primaryApp        String?
  primaryUrl        String?
  category          ActivityCategory @default(OTHER)

  session TimeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  device  AgentDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([deviceId])
  @@index([timestamp])
}

model AppUsageSummary {
  id             String           @id @default(cuid())
  employeeId     String
  organizationId String
  date           DateTime
  appName        String
  category       ActivityCategory @default(OTHER)
  totalSeconds   Int              @default(0)

  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([employeeId, date, appName])
  @@index([organizationId, date])
  @@index([employeeId, date])
}

model WebsiteUsageSummary {
  id             String           @id @default(cuid())
  employeeId     String
  organizationId String
  date           DateTime
  domain         String
  category       ActivityCategory @default(OTHER)
  totalSeconds   Int              @default(0)

  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([employeeId, date, domain])
  @@index([organizationId, date])
  @@index([employeeId, date])
}

model IdleEvent {
  id             String       @id @default(cuid())
  sessionId      String
  employeeId     String
  organizationId String
  startedAt      DateTime
  endedAt        DateTime?
  durationSec    Int          @default(0)
  response       IdleResponse @default(TIMEOUT)
  notes          String?
  createdAt      DateTime     @default(now())

  session      TimeSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([sessionId])
  @@index([employeeId, createdAt])
  @@index([organizationId])
}

model DailyActivityReport {
  id                     String   @id @default(cuid())
  employeeId             String
  organizationId         String
  date                   DateTime
  totalActiveSeconds     Int      @default(0)
  totalIdleSeconds       Int      @default(0)
  totalBreakSeconds      Int      @default(0)
  totalSessionSeconds    Int      @default(0)
  productivityScore      Float?
  focusScore             Float?
  topApps                Json?
  topWebsites            Json?
  aiSummary              String?  @db.Text
  aiRecommendations      String?  @db.Text
  burnoutRiskFlag        Boolean  @default(false)
  snapshotCount          Int      @default(0)
  idleEventCount         Int      @default(0)
  emailSentAt            DateTime?
  generatedAt            DateTime @default(now())

  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([employeeId, date])
  @@index([organizationId, date])
}

// ─── Reimbursement Module ───

enum ReimbursementCategory {
  TRAVEL
  MEALS
  OFFICE_SUPPLIES
  MEDICAL
  TRAINING_EXPENSE
  CONFERENCE
  RELOCATION
  OTHER
}

enum ReimbursementStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model Reimbursement {
  id             String                @id @default(cuid())
  employeeId     String
  organizationId String
  category       ReimbursementCategory
  amount         Float
  description    String                @db.Text
  receiptUrl     String?
  expenseDate    DateTime
  status         ReimbursementStatus   @default(PENDING)
  approvedBy     String?
  approvedAt     DateTime?
  rejectionNote  String?
  paidInMonth    String?               // Payroll month when reimbursement was disbursed
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([employeeId])
  @@index([organizationId])
  @@index([status])
  @@index([organizationId, status])
}
