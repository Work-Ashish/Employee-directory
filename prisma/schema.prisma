generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Organization {
  id                 String               @id @default(cuid())
  name               String
  domain             String?              @unique
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  users              User[]
  employees          Employee[]
  departments        Department[]
  announcements      Announcement[]
  candidates         Candidate[]
  leaves             Leave[]
  attendances        Attendance[]
  tickets            Ticket[]
  performanceMetrics PerformanceMetrics[]
  weeklyScores       WeeklyScores[]
  notifications      Notifications[]
  adminAlerts        AdminAlerts[]
  assets             Asset[]
  documents          Document[]
  payroll            Payroll[]
  providentFunds     ProvidentFund[]
  performanceReviews PerformanceReview[]
  resignations       Resignation[]
  trainings          Training[]
  events             CalendarEvent[]
  trainingEnrollments TrainingEnrollment[]
  documentEmbeddings DocumentEmbedding[]

  // Workflows
  workflowTemplates  WorkflowTemplate[]
  workflowInstances  WorkflowInstance[]

  // RBAC Redesign
  teams              Team[]
  employeeFeedback   EmployeeFeedback[]
  auditLogs          AuditLog[]

  // Attendance Policy (Week 7)
  shifts             Shift[]
  shiftAssignments   ShiftAssignment[]
  attendancePolicies AttendancePolicy[]
  holidays           Holiday[]
  regularizations    AttendanceRegularization[]

  // Payroll Configs
  payrollConfigs     PayrollComplianceConfig[]
  payrollAudits      PayrollAudit[]

  // Integrations (Week 8)
  webhooks           Webhook[]
  kudos              Kudos[]

  // Agent Tracking
  agentDevices           AgentDevice[]
  appUsageSummaries      AppUsageSummary[]
  websiteUsageSummaries  WebsiteUsageSummary[]
  idleEvents             IdleEvent[]
  dailyActivityReports   DailyActivityReport[]

  // Reimbursements
  reimbursements         Reimbursement[]

  // Enterprise Identity (Week 9)
  scimSecret         String?      @unique
  userSessions       UserSession[]

  // Reporting & Analytics (Week 10)
  savedReports       SavedReport[]
  reportSchedules    ReportSchedule[]
  inAppNotifications InAppNotification[]

  // Performance Templates
  performanceTemplate PerformanceTemplate?
}

model User {
  id                 String        @id @default(cuid())
  name               String
  email              String        @unique
  hashedPassword     String
  role               Role          @default(EMPLOYEE)
  organizationId     String
  organization       Organization  @relation(fields: [organizationId], references: [id])
  avatar             String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  accentColor        String?       @default("blue")
  bio                String?
  lastLoginAt        DateTime?
  mustChangePassword Boolean       @default(false)
  employee           Employee?
  sessions           UserSession[]
}

model Department {
  id             String        @id @default(cuid())
  name           String
  color          String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  candidates     Candidate[]
  employees      Employee[]

  @@index([organizationId])
  @@unique([name, organizationId])
}

model Employee {
  id             String         @id @default(cuid())
  employeeCode   String         @unique
  firstName      String
  lastName       String
  email          String         @unique
  phone          String?
  designation    String
  departmentId   String
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  dateOfJoining  DateTime
  salary         Float
  status         EmployeeStatus @default(ACTIVE)
  avatarUrl      String?
  address        String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  userId         String?        @unique
  managerId      String?

  // Soft delete (RBAC Redesign)
  deletedAt      DateTime?
  isArchived     Boolean        @default(false)

  // Sub-profiles
  profile     EmployeeProfile?
  addressInfo EmployeeAddress?
  banking     EmployeeBanking?

  // Relations
  assets             Asset[]
  attendanceRecords  Attendance[]
  documents          Document[]
  educations         Education[]
  department         Department           @relation(fields: [departmentId], references: [id])
  manager            Employee?            @relation("EmployeeToManager", fields: [managerId], references: [id])
  reports            Employee[]           @relation("EmployeeToManager")
  user               User?                @relation(fields: [userId], references: [id])
  leaves             Leave[]
  payrollRecords     Payroll[]
  performanceReviews PerformanceReview[]
  reviewsConducted   PerformanceReview[]  @relation("ReviewedBy")
  pfRecords          ProvidentFund[]
  resignations       Resignation[]
  tickets            Ticket[]
  trainings          TrainingEnrollment[]
  timeSessions       TimeSession[]
  performanceMetrics PerformanceMetrics[]
  weeklyScores       WeeklyScores[]
  notifications      Notifications[]
  adminAlerts        AdminAlerts[]
  shiftAssignments   ShiftAssignment[]
  regularizations    AttendanceRegularization[]

  // Teams & Feedback (RBAC Redesign)
  teamMemberships    TeamMember[]
  teamsLed           Team[]               @relation("TeamLead")
  feedbackGiven      EmployeeFeedback[]   @relation("FeedbackGiven")
  feedbackReceived   EmployeeFeedback[]   @relation("FeedbackReceived")

  // Workflows
  requestedWorkflows WorkflowInstance[] @relation("WorkflowRequester")
  workflowActions    WorkflowAction[]   @relation("WorkflowActor")
  kudosSent          Kudos[]            @relation("KudosSent")
  kudosReceived      Kudos[]            @relation("KudosReceived")

  // Agent Tracking
  agentDevices           AgentDevice[]
  appUsageSummaries      AppUsageSummary[]
  websiteUsageSummaries  WebsiteUsageSummary[]
  idleEvents             IdleEvent[]
  dailyActivityReports   DailyActivityReport[]

  // Reimbursements
  reimbursements         Reimbursement[]

  @@index([departmentId])
  @@index([userId])
  @@index([managerId])
  @@index([email])
  @@index([status])
  @@index([organizationId])
}

model EmployeeProfile {
  id         String   @id @default(cuid())
  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // Personal
  dateOfBirth           DateTime?
  gender                String?
  bloodGroup            String?
  nationality           String?
  maritalStatus         String?
  marriageDate          DateTime?
  spouse                String?
  placeOfBirth          String?
  residentialStatus     String?
  fatherName            String?
  religion              String?
  physicallyChallenged  Boolean?  @default(false)
  internationalEmployee Boolean?  @default(false)
  hobby                 String?
  caste                 String?
  height                String?
  weight                String?
  identificationMark    String?

  // Family – Father
  fatherDob         DateTime?
  fatherBloodGroup  String?
  fatherGender      String?
  fatherNationality String?

  // Emergency Contact
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?

  // Employment extras
  category           String?
  costCenter         String?
  division           String?
  grade              String?
  location           String?
  previousEmployment String?

  // Passport & Visa
  passportNumber String?
  passportExpiry DateTime?
  visaNumber     String?
  visaExpiry     DateTime?
}

model EmployeeAddress {
  id         String   @id @default(cuid())
  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // Current/Contact Address
  contactAddress String?
  contactCity    String?
  contactState   String?
  contactPincode String?

  // Permanent Address
  permanentAddress String?
  permanentCity    String?
  permanentState   String?
  permanentPincode String?
}

model EmployeeBanking {
  id         String   @id @default(cuid())
  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // Bank & Statutory
  bankName          String?
  bankAccountNumber String?
  bankBranch        String?
  ifscCode          String?
  pfAccountNumber   String?
  aadhaarNumber     String?
  panNumber         String?
}

model Education {
  id         String   @id @default(cuid())
  degree     String
  institute  String
  duration   String?
  grade      String?
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

model Asset {
  id             String       @id @default(cuid())
  name           String
  type           AssetType
  serialNumber   String       @unique
  status         AssetStatus  @default(AVAILABLE)
  purchaseDate   DateTime
  value          Float
  image          String?
  assignedToId   String?
  assignedDate   DateTime?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  assignedTo     Employee?    @relation(fields: [assignedToId], references: [id])

  @@index([assignedToId])
  @@index([status])
  @@index([organizationId])
}

model Document {
  id             String       @id @default(cuid())
  title          String
  category       DocCategory
  url            String
  size           String?
  isPublic       Boolean      @default(false)
  employeeId     String?
  organizationId String
  uploadDate     DateTime     @default(now())
  employee       Employee?    @relation(fields: [employeeId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([employeeId])
  @@index([organizationId])
}

model Leave {
  id             String        @id @default(cuid())
  type           LeaveType
  startDate      DateTime
  endDate        DateTime
  reason         String?
  status         LeaveStatus   @default(PENDING)
  employeeId     String
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  employee       Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization   Organization  @relation(fields: [organizationId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([employeeId, startDate, endDate])
  @@index([organizationId])
}

model Resignation {
  id             String            @id @default(cuid())
  reason         String
  lastDay        DateTime
  status         ResignationStatus @default(UNDER_REVIEW)
  employeeId     String
  organizationId String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  employee       Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization   Organization      @relation(fields: [organizationId], references: [id])

  @@index([employeeId])
  @@index([organizationId])
}

model Attendance {
  id             String           @id @default(cuid())
  date           DateTime
  checkIn        DateTime?
  checkOut       DateTime?
  workHours      Float?
  
  // Policy Engine Results (Week 7)
  overtime       Float?           @default(0) // In minutes
  isLate         Boolean          @default(false)
  isEarlyExit    Boolean          @default(false)
  
  status         AttendanceStatus @default(PRESENT)
  employeeId     String
  organizationId String
  createdAt      DateTime         @default(now())
  
  employee       Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id])
  regularization AttendanceRegularization?

  @@index([employeeId])
  @@index([date])
  @@index([employeeId, date])
  @@index([organizationId])
}

// ─── Phase 2: Core HRMS Phase 2 - Attendance Policy Engine (Week 7) ───

model Shift {
  id             String       @id @default(cuid())
  name           String
  startTime      String       // HH:mm
  endTime        String       // HH:mm
  workDays       Int[]        // 0-6 (Sun-Sat)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  assignments    ShiftAssignment[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model ShiftAssignment {
  id             String       @id @default(cuid())
  employeeId     String
  shiftId        String
  startDate      DateTime
  endDate        DateTime?
  organizationId String
  
  employee       Employee     @relation(fields: [employeeId], references: [id])
  shift          Shift        @relation(fields: [shiftId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([employeeId])
  @@index([shiftId])
  @@index([organizationId])
}

model AttendancePolicy {
  id                String       @id @default(cuid())
  name              String       @default("DEFAULT")
  lateGracePeriod   Int          @default(15) // Minutes
  earlyExitGrace    Int          @default(15) // Minutes
  otThreshold       Int          @default(60) // Extra minutes before OT starts
  organizationId    String       @unique
  organization      Organization @relation(fields: [organizationId], references: [id])
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model PerformanceTemplate {
  id                  String       @id @default(cuid())
  organizationId      String       @unique
  dailyMetrics        Json         @default("[]")
  dailyCompetencies   Json         @default("[]")
  monthlyKpis         Json         @default("[]")
  monthlyCompetencies Json         @default("[]")
  selfCompetencies    Json         @default("[]")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  organization        Organization @relation(fields: [organizationId], references: [id])
}

model AttendanceRegularization {
  id             String           @id @default(cuid())
  attendanceId   String           @unique
  reason         String
  requestedTime  DateTime?        // Corrected CheckIn or CheckOut time
  type           RegularizationType
  status         RegularizationStatus @default(PENDING)
  notes          String?
  employeeId     String
  organizationId String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  attendance     Attendance       @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id])
  employee       Employee         @relation(fields: [employeeId], references: [id])
  
  @@index([organizationId])
  @@index([employeeId])
}

model Holiday {
  id             String       @id @default(cuid())
  name           String
  date           DateTime
  isOptional     Boolean      @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([date])
}

enum RegularizationType {
  MISSING_PUNCH
  LATE_CORRECTION
  EARLY_EXIT_CORRECTION
}

enum RegularizationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Phase 2: Core HRMS Phase 2 - Payroll Compliance ───

model Payroll {
  id             String       @id @default(cuid())
  month          String
  basicSalary    Float
  allowances     Float        @default(0)
  pfDeduction    Float        @default(0)
  tax            Float        @default(0)
  otherDed       Float        @default(0)

  // Advanced Components (New)
  arrears        Float        @default(0)
  reimbursements Float        @default(0)
  loansAdvances  Float        @default(0)

  netSalary      Float
  status         PayrollStatus @default(PENDING)
  isFinalized    Boolean      @default(false)
  pdfUrl         String?
  
  employeeId     String
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  
  employee       Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization   Organization  @relation(fields: [organizationId], references: [id])
  audits         PayrollAudit[]

  @@unique([employeeId, month])
  @@index([employeeId])
  @@index([organizationId])
  @@index([organizationId, month])
}

model ProvidentFund {
  id                   String       @id @default(cuid())
  month                String
  accountNumber        String
  basicSalary          Float
  employeeContribution Float
  employerContribution Float
  totalContribution    Float
  status               String       @default("Credited")
  employeeId           String
  organizationId       String
  createdAt            DateTime     @default(now())
  employee             Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization         Organization @relation(fields: [organizationId], references: [id])

  @@index([employeeId])
  @@index([organizationId])
}

model PerformanceReview {
  id             String            @id @default(cuid())
  rating         Float
  progress       Int               @default(0)
  comments       String?
  reviewDate     DateTime          @default(now())
  status         PerformanceStatus @default(PENDING)
  employeeId     String
  organizationId String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  // RBAC Redesign: reviewer tracking
  reviewerId     String?
  reviewType     ReviewType        @default(MANAGER)
  reviewPeriod   String?           // e.g. "2026-Q1", "2026-H1", "2026"

  // Structured form data for Daily/Monthly reviews
  formType       String?           // "DAILY" or "MONTHLY" (null = legacy)
  formData       Json?             // Structured form sections as JSON

  employee       Employee          @relation(fields: [employeeId], references: [id])
  reviewer       Employee?         @relation("ReviewedBy", fields: [reviewerId], references: [id])
  organization   Organization      @relation(fields: [organizationId], references: [id])

  @@index([employeeId])
  @@index([organizationId])
  @@index([reviewerId])
}

model Training {
  id             String               @id @default(cuid())
  name           String
  type           TrainingType
  description    String?
  status         TrainingStatus       @default(UPCOMING)
  progress     Int                  @default(0)
  dueDate      DateTime?
  participants Int                  @default(0)
  videoUrl     String?
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id])
  createdAt    DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  enrollments  TrainingEnrollment[]

  @@index([organizationId])
}

model TrainingEnrollment {
  id             String       @id @default(cuid())
  score          Int?
  completed      Boolean      @default(false)
  trainingId     String
  employeeId     String
  organizationId String
  enrolledAt     DateTime     @default(now())
  employee       Employee     @relation(fields: [employeeId], references: [id])
  training       Training     @relation(fields: [trainingId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([trainingId, employeeId])
  @@index([organizationId])
}

model Announcement {
  id             String               @id @default(cuid())
  title          String
  content        String
  author         String
  category       AnnouncementCategory
  priority       AnnouncementPriority @default(MEDIUM)
  isPinned       Boolean              @default(false)
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id])
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([organizationId])
}

model Ticket {
  id             String         @id @default(cuid())
  ticketCode     String         @unique
  subject        String
  description    String?
  category       TicketCategory
  priority       TicketPriority @default(MEDIUM)
  status         TicketStatus   @default(OPEN)
  employeeId     String
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  employee       Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization   Organization   @relation(fields: [organizationId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([organizationId])
}

model CalendarEvent {
  id             String       @id @default(cuid())
  title          String
  start          DateTime
  end            DateTime
  allDay         Boolean      @default(false)
  type           EventType    @default(EVENT)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([organizationId])
}

model Candidate {
  id             String          @id @default(cuid())
  name           String
  email          String
  phone          String?
  role           String
  stage          CandidateStage  @default(APPLICATION)
  status         CandidateStatus @default(NEW)
  interviewDate  DateTime?
  notes          String?
  departmentId   String?
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  department     Department?     @relation(fields: [departmentId], references: [id])

  @@index([organizationId])
}

model DocumentEmbedding {
  id             String                          @id @default(cuid())
  content        String
  embedding      Unsupported("vector(1536)")
  metadata       Json?
  organizationId String
  organization   Organization                    @relation(fields: [organizationId], references: [id])
  createdAt      DateTime                        @default(now())

  @@index([organizationId])
}

// ─── Time Tracking ───

model TimeSession {
  id         String             @id @default(cuid())
  employeeId String
  checkIn    DateTime           @default(now())
  checkOut   DateTime?
  totalWork  Int                @default(0)
  totalBreak Int                @default(0)
  totalIdle  Int                @default(0)
  status     SessionStatus      @default(ACTIVE)
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime           @default(now())
  employee   Employee           @relation(fields: [employeeId], references: [id])
  breaks     BreakEntry[]
  activities ActivityLog[]
  snapshots       ActivitySnapshot[]
  agentSnapshots  AgentActivitySnapshot[]
  idleEvents      IdleEvent[]

  @@index([employeeId])
  @@index([createdAt])
  @@index([employeeId, createdAt])
}

model BreakEntry {
  id        String      @id @default(cuid())
  sessionId String
  startedAt DateTime    @default(now())
  endedAt   DateTime?
  reason    String?
  session   TimeSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
}

model ActivityLog {
  id          String           @id @default(cuid())
  sessionId   String
  appName     String
  windowTitle String?
  url         String?
  domain      String?
  category    ActivityCategory @default(OTHER)
  startedAt   DateTime         @default(now())
  endedAt     DateTime?
  durationSec Int              @default(0)
  session     TimeSession      @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
}

model ActivitySnapshot {
  id          String         @id @default(cuid())
  sessionId   String
  status      ActivityStatus @default(ACTIVE)
  timestamp   DateTime       @default(now())
  mouseClicks Int            @default(0)
  keystrokes  Int            @default(0)
  session     TimeSession    @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
}

// --- PHASE 6: AUTONOMOUS PERFORMANCE MONITORING AGENT ---

model PerformanceMetrics {
  id             String    @id @default(cuid())
  employeeId     String
  date           DateTime
  activeSeconds  Int       @default(0)
  idleSeconds    Int       @default(0)
  tasksCompleted Int       @default(0)
  qualityScore   Decimal?  @db.Decimal(5, 2)
  organizationId String
  
  employee     Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([employeeId, date])
  @@index([organizationId])
}

model WeeklyScores {
  id               String    @id @default(cuid())
  evaluationHash   String    @unique // Format: emp123_2026_w42
  employeeId       String
  weekStartDate    DateTime
  baseScore        Decimal   @db.Decimal(5, 2)
  aiAdjustment     Decimal   @db.Decimal(5, 2)
  finalScore       Decimal   @db.Decimal(5, 2)
  confidenceScore  Decimal   @db.Decimal(5, 2) 
  burnoutRisk      Boolean   @default(false)
  behavioralAnomaly Boolean  @default(false)
  aiFeedback       String?   @db.Text
  organizationId   String

  employee      Employee      @relation(fields: [employeeId], references: [id])
  organization  Organization  @relation(fields: [organizationId], references: [id])
  notifications Notifications[]

  @@index([employeeId])
  @@index([organizationId])
}

model AgentExecutionLogs {
  id                 String    @id @default(cuid())
  batchId            String
  weekNumber         Int
  employeesProcessed Int       @default(0)
  errors             Int       @default(0)
  status             AgentRunStatus @default(RUNNING)
  durationMs         Int       @default(0)
  createdAt          DateTime  @default(now())
}

model Notifications {
  id             String    @id @default(cuid())
  employeeId     String
  type           NotificationType
  evaluationHash String    @unique
  status         NotificationStatus @default(PENDING)
  sentAt         DateTime?
  organizationId String

  employee     Employee      @relation(fields: [employeeId], references: [id])
  weeklyScore  WeeklyScores  @relation(fields: [evaluationHash], references: [evaluationHash])
  organization Organization  @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model AdminAlerts {
  id             String    @id @default(cuid())
  employeeId     String
  severity       AdminAlertSeverity
  reason         String    @db.Text
  resolved       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  organizationId String
  
  employee     Employee      @relation(fields: [employeeId], references: [id])
  organization Organization  @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model Kudos {
  id             String       @id @default(cuid())
  message        String
  fromId         String
  toId           String
  organizationId String
  createdAt      DateTime     @default(now())

  from         Employee     @relation("KudosSent", fields: [fromId], references: [id], onDelete: SetNull)
  to           Employee     @relation("KudosReceived", fields: [toId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([fromId])
  @@index([toId])
  @@index([organizationId])
}

model UserSession {
  id             String       @id @default(cuid())
  sessionToken   String       @unique
  userId         String
  organizationId String
  expires        DateTime
  userAgent      String?
  ipAddress      String?
  isRevoked      Boolean      @default(false)
  lastActive     DateTime     @default(now())
  createdAt      DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
}

// ─── RBAC Redesign: Teams, Feedback, AuditLog ───

model Team {
  id             String       @id @default(cuid())
  name           String
  description    String?
  leadId         String
  createdById    String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  lead           Employee     @relation("TeamLead", fields: [leadId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  members        TeamMember[]

  @@unique([name, organizationId])
  @@index([organizationId])
  @@index([leadId])
}

model TeamMember {
  id         String   @id @default(cuid())
  teamId     String
  employeeId String
  joinedAt   DateTime @default(now())

  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id])

  @@unique([teamId, employeeId])
  @@index([employeeId])
}

model EmployeeFeedback {
  id             String       @id @default(cuid())
  fromEmployeeId String?
  toEmployeeId   String
  content        String       @db.Text
  rating         Int          // 1-5
  isAnonymous    Boolean      @default(false)
  period         String       // e.g. "2026-Q1"
  organizationId String
  createdAt      DateTime     @default(now())

  fromEmployee   Employee?    @relation("FeedbackGiven", fields: [fromEmployeeId], references: [id])
  toEmployee     Employee     @relation("FeedbackReceived", fields: [toEmployeeId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([fromEmployeeId, toEmployeeId, period])
  @@index([toEmployeeId])
  @@index([organizationId])
}

model AuditLog {
  id             String       @id @default(cuid())
  userId         String
  action         String       // e.g. "CREATE", "UPDATE", "DELETE"
  entityType     String       // e.g. "Employee", "Payroll", "Leave"
  entityId       String?
  changes        Json?
  ipAddress      String?
  userAgent      String?
  organizationId String
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
  @@index([userId])
  @@index([entityType, entityId])
}

enum ReviewType {
  MANAGER
  SELF
  PEER
}

